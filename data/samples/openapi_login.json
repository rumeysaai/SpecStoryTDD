{
  "openapi": "3.1.0",
  "info": {
    "title": "Auth API (Sample — contains intentional conflicts for demo purposes)",
    "version": "1.0.0",
    "description": "Minimal authentication API used to demonstrate SpecStoryTDD conflict detection."
  },
  "paths": {
    "/login": {
      "post": {
        "operationId": "login",
        "summary": "Authenticate a user",
        "tags": ["auth"],
        "requestBody": {
          "required": true,
          "content": {
            "application/json": {
              "schema": {
                "type": "object",
                "required": ["email", "password"],
                "properties": {
                  "email": {
                    "type": "string",
                    "format": "email"
                  },
                  "password": {
                    "type": "string"
                  }
                }
              }
            }
          }
        },
        "responses": {
          "200": {
            "description": "Successful authentication",
            "content": {
              "application/json": {
                "schema": {
                  "type": "object",
                  "properties": {
                    "access_token": {
                      "type": "string",
                      "description": "JWT access token (no expiry specified — CONFLICT with AC #4)"
                    },
                    "password": {
                      "type": "string",
                      "description": "INTENTIONAL CONFLICT: password must not be exposed (AC #3)"
                    }
                  }
                }
              }
            }
          },
          "400": {
            "description": "Bad Request — CONFLICT: AC #2 requires 401, not 400"
          }
        }
      }
    }
  }
}
